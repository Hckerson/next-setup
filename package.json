{
    "name": "next-app-starter",
    "version": "0.1.0",
    "description": "Domain-neutral Next.js App Router starter with token-driven design system.",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "format": "prettier --write .",
        "type-check": "tsc --noEmit",
        "lint": "eslint",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{js,mjs,json,css,md}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@tanstack/react-query": "^5.101.2",
        "axios": "^1.18.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.4.0",
        "lucide-react": "^1.25.0",
        "motion": "^12.42.2",
        "next": "16.2.10",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@tanstack/react-query-devtools": "^5.101.2",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.2.10",
        "husky": "^9.1.7",
        "lint-staged": "^17.1.0",
        "prettier": "^3.9.5",
        "prettier-plugin-tailwindcss": "^0.8.1",
        "tailwindcss": "^4",
        "typescript": "^5"
    }
}
